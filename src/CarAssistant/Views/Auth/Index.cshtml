@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Вход / Регистрация · Car Assistant</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

</head>
<body class="bg-slate-950 text-slate-200 antialiased">
<div class="relative min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950">
    <div class="absolute -top-20 -left-20 w-96 h-96 bg-purple-600/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-1/3 -right-20 w-80 h-80 bg-cyan-600/20 rounded-full blur-3xl animate-pulse [animation-delay:2s]"></div>
    <div class="absolute bottom-10 left-1/4 w-72 h-72 bg-pink-500/20 rounded-full blur-3xl animate-pulse [animation-delay:1.5s]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-purple-950/20 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative w-full max-w-md backdrop-blur-sm bg-slate-900/50 border border-slate-800 rounded-3xl shadow-2xl shadow-purple-500/10 p-6 md:p-8 transition-all duration-300 hover:shadow-purple-500/20">
        <div class="text-center mb-8">
            <div class="text-4xl font-bold bg-gradient-logo bg-clip-text text-transparent mb-1">🚗 Car Assistant</div>
            <h2 class="text-3xl md:text-4xl font-bold text-gradient-headline mt-2">Добро пожаловать</h2>
        </div>
        <div class="flex gap-2 p-1 bg-slate-800/60 border border-slate-700 rounded-2xl mb-4">
            <button id="loginTabBtn" class="tab-btn active-tab flex-1 py-3 text-sm font-medium rounded-xl transition-all duration-200 bg-purple-600/20 text-purple-300 border border-purple-500/30 shadow-sm">Вход</button>
            <button id="registerTabBtn" class="tab-btn flex-1 py-3 text-sm font-medium rounded-xl transition-all duration-200 text-slate-300 hover:bg-white/5 border border-transparent">Регистрация</button>
        </div>
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-4 text-sm text-rose-400 space-y-1">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }
        <div id="loginForm" class="form-panel transition-all duration-300">
            <form asp-action="Login" asp-controller="Auth" method="post">
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Электронная почта</label>
                        <input name="Email" type="email" placeholder="name@example.com" required
                               class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Пароль</label>
                        <input name="Password" type="password" placeholder="••••••••" required
                               class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
                    </div>
                    <button type="submit"
                            class="group relative w-full py-3.5 px-4 bg-gradient-to-r from-purple-600 to-cyan-600 text-white font-semibold rounded-xl shadow-lg shadow-purple-500/50 hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                        <span class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                        <span class="relative flex items-center justify-center gap-2">
                            войти
                            <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </span>
                    </button>
                </div>
            </form>
        </div>

        <div id="registerForm" class="form-panel hidden transition-all duration-300">
            <form asp-action="Register" asp-controller="Auth" method="post">
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Электронная почта</label>
                        <input name="Email" type="email" placeholder="name@example.com" required
                               class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Пароль</label>
                        <input name="Password" type="password" placeholder="минимум 8 символов" required minlength="6"
                               class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Подтвердите пароль</label>
                        <input name="ConfirmPassword" type="password" placeholder="введите ещё раз" required
                               class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
                    </div>
                    <button type="submit"
                            class="group relative w-full py-3.5 px-4 bg-gradient-to-r from-purple-600 to-cyan-600 text-white font-semibold rounded-xl shadow-lg shadow-purple-500/50 hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                        <span class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                        <span class="relative flex items-center justify-center gap-2">
                            создать аккаунт
                            <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </span>
                    </button>

                    <p class="text-xs text-center text-slate-500">нажимая кнопку, вы соглашаетесь с условиями</p>
                </div>
            </form>
        </div>
    </div>
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center text-slate-600 animate-bounce">
        <span class="text-xs">⋮⋮⋮</span>
    </div>
</div>


<script src="~/js/auth.js"></script>

</body>
</html>