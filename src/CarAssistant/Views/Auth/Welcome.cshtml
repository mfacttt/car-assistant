@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Добавить машину · Менеджер расходов</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/welcome.css" asp-append-version="true" />
   
</head>
<body class="bg-slate-950 text-slate-200 antialiased min-h-screen flex items-center justify-center p-4">
<div class="fixed inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 -z-10"></div>
<div class="fixed inset-0 bg-gradient-to-b from-purple-950/20 via-transparent to-transparent pointer-events-none -z-10"></div>
<div class="fixed -top-20 -left-20 w-96 h-96 bg-purple-600/20 rounded-full blur-3xl animate-pulse -z-10"></div>
<div class="fixed -bottom-20 -right-20 w-80 h-80 bg-cyan-600/20 rounded-full blur-3xl animate-pulse [animation-delay:2s] -z-10"></div>
<div class="relative w-full max-w-md backdrop-blur-sm bg-slate-900/50 border border-slate-800 rounded-3xl shadow-2xl shadow-purple-500/10 p-6 md:p-8 transition-all duration-300 hover:shadow-purple-500/20">
    <div class="text-center mb-6">
        <div class="text-3xl font-bold bg-gradient-logo bg-clip-text text-transparent mb-1">🚗 Car Assistant</div>
        <div class="text-xl font-medium text-slate-300 tracking-wide">Добавим первую машину</div>
    </div>
    <form asp-action="SaveCar" asp-controller="Auth" method="post" class="space-y-5">
        <div>
            <label class="block text-sm font-medium text-slate-300 mb-1">Марка <span class="text-rose-400">*</span></label>
            <input type="text" name="brand" placeholder="Например: Toyota, BMW" required
                   class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-300 mb-1">Модель <span class="text-rose-400">*</span></label>
            <input type="text" name="model" placeholder="Camry, X5" required
                   class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-300 mb-1">Вид топлива <span class="text-rose-400">*</span></label>
            <select name="fuelType" required class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 appearance-none">
                <option value="бензин" selected class="bg-slate-800">Бензин</option>
                <option value="дизель" class="bg-slate-800">Дизель</option>
                <option value="электричество" class="bg-slate-800">Электричество</option>
                <option value="гибрид" class="bg-slate-800">Гибрид</option>
                <option value="газ" class="bg-slate-800">Газ</option>
            </select>
            <div class="relative -mt-9 ml-auto mr-3 w-5 h-5 pointer-events-none text-slate-400">▼</div>
        </div>
        <div class="grid grid-cols-1 gap-5 pt-2">
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">VIN‑код (ID машины) <span class="text-rose-400">*</span></label>
                <input type="text" name="vin" placeholder="WAUZZZ8KX9A123456" maxlength="17" required
                       class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200 uppercase">
                <p class="text-xs text-slate-500 mt-1">17 символов, уникальный номер</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Пробег <span class="text-rose-400">*</span> <span class="text-slate-500">(км)</span></label>
                <input type="number" name="mileage" placeholder="12500" min="0" step="1" required
                       class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
            </div>
        </div>
        <div class="grid grid-cols-1 gap-5">
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Год выпуска <span class="text-rose-400">*</span></label>
                <select name="year" required class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 appearance-none">
                    @{
                        var currentYear = DateTime.UtcNow.Year;
                    }
                    @for (var year = currentYear; year >= 1980; year--)
                    {
                        <option value="@year" class="bg-slate-800">@year</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Объём двигателя (л) <span class="text-rose-400">*</span></label>
                <input type="number" name="engineVolume" placeholder="1.6" min="0.1" step="0.1" required
                       class="w-full px-4 py-3 bg-slate-800/40 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 text-slate-200 placeholder-slate-500 transition-all duration-200">
            </div>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gradient-to-r from-purple-950/20 to-cyan-950/10 border border-purple-500/20 rounded-xl mt-4">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-pink-500 flex items-center justify-center text-white text-sm">💰</div>
            <p class="text-xs text-slate-300 leading-relaxed">После добавления вы сможете управлять <span class="text-purple-300 font-medium">расходами</span> в личном кабинете.</p>
        </div>
        <button type="submit"
                class="group relative w-full py-4 px-4 bg-gradient-to-r from-purple-600 to-cyan-600 text-white font-semibold text-lg rounded-xl shadow-lg shadow-purple-500/50 hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300 overflow-hidden mt-4">
            <span class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></span>
            <span class="relative flex items-center justify-center gap-2">
                Добавить машину
                <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </span>
        </button>
    </form>
</div>
<div class="fixed bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center text-slate-600 animate-bounce opacity-50">
    <span class="text-xs">⋮⋮⋮</span>
</div>
<script src="~/js/welcome.js" asp-append-version="true"></script>

</body>
</html>